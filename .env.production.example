# =====================================================
# CustomERP - PRODUCTION Environment Variables
# =====================================================
# Copy this file to .env and fill in real values before deploying.
#   cp .env.production.example .env
#   nano .env
# =====================================================

# ─── Domain ──────────────────────────────────────────
DOMAIN=customerp.site

# ─── Let's Encrypt ───────────────────────────────────
CERTBOT_EMAIL=admin@customerp.site

# ─── PostgreSQL ──────────────────────────────────────
POSTGRES_USER=customwerp
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD
POSTGRES_DB=customwerp

# ─── Backend ─────────────────────────────────────────
NODE_ENV=production
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_-base64_48

# ─── Frontend (build-time arg) ───────────────────────
# Relative path; nginx proxies /api to the backend container.
VITE_API_URL=/api

# ─── AI Gateway URL (backend → ai-gateway, internal) ─
AI_GATEWAY_URL=http://ai-gateway:8000

# ─── AI Provider Selection (azure_openai | gemini) ───
AI_DEFAULT_PROVIDER=azure_openai

# ─── Azure OpenAI (primary) ─────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ─── Google Gemini (fallback) ────────────────────────
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── AI Gateway Server ──────────────────────────────
AI_TIMEOUT_SECONDS=120
AI_MAX_RETRIES=3
LOG_LEVEL=INFO
DEBUG=false

# ─── Per-Agent Azure Deployment Overrides ────────────
# Leave blank to use AZURE_OPENAI_DEPLOYMENT for all agents.
AI_AGENT_DISTRIBUTOR_AZURE_DEPLOYMENT=
AI_AGENT_HR_AZURE_DEPLOYMENT=
AI_AGENT_INVOICE_AZURE_DEPLOYMENT=
AI_AGENT_INVENTORY_AZURE_DEPLOYMENT=
AI_AGENT_INTEGRATOR_AZURE_DEPLOYMENT=
AI_AGENT_CHATBOT_AZURE_DEPLOYMENT=

# ─── Per-Agent Provider Overrides ────────────────────
# Set to "gemini" to route a specific agent to Gemini.
AI_AGENT_DISTRIBUTOR_PROVIDER=
AI_AGENT_HR_PROVIDER=
AI_AGENT_INVOICE_PROVIDER=
AI_AGENT_INVENTORY_PROVIDER=
AI_AGENT_INTEGRATOR_PROVIDER=
AI_AGENT_CHATBOT_PROVIDER=

# ─── Per-Agent Temperature Overrides ─────────────────
AI_AGENT_DISTRIBUTOR_TEMPERATURE=0.1
AI_AGENT_HR_TEMPERATURE=0.2
AI_AGENT_INVOICE_TEMPERATURE=0.2
AI_AGENT_INVENTORY_TEMPERATURE=0.2
AI_AGENT_INTEGRATOR_TEMPERATURE=0.1
AI_AGENT_CHATBOT_TEMPERATURE=0.7
