# ─────────────────────────────────────────────────────────────
# CustomERP AI Gateway - Environment Configuration
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────
# Provider Selection  (azure_openai | gemini)
# Azure OpenAI is the primary provider; Gemini is the fallback.
# ─────────────────────────────────────────────────────────────
AI_DEFAULT_PROVIDER=azure_openai

# ─────────────────────────────────────────────────────────────
# Azure OpenAI  (primary)
# ─────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=xx
AZURE_OPENAI_ENDPOINT=https://custom-erp-ai.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o


# ─────────────────────────────────────────────────────────────
# Google Gemini  (fallback)
# ─────────────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=xx
GEMINI_MODEL=gemini-2.5-flash

# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
# Global Defaults (fallback for all agents)
# ─────────────────────────────────────────────────────────────
AI_TIMEOUT_SECONDS=120
AI_MAX_RETRIES=3

# ─────────────────────────────────────────────────────────────
# Per-Agent Provider Override
# Set to "gemini" to use Gemini for a specific agent.
# Leave blank to use AI_DEFAULT_PROVIDER.
# ─────────────────────────────────────────────────────────────
AI_AGENT_DISTRIBUTOR_PROVIDER=
AI_AGENT_HR_PROVIDER=
AI_AGENT_INVOICE_PROVIDER=
AI_AGENT_INVENTORY_PROVIDER=
AI_AGENT_INTEGRATOR_PROVIDER=

# ─────────────────────────────────────────────────────────────
# Per-Agent Azure Deployment Overrides
# Each agent can target a different Azure deployment / model.
# Leave blank to use AZURE_OPENAI_DEPLOYMENT.
# ─────────────────────────────────────────────────────────────
AI_AGENT_DISTRIBUTOR_AZURE_DEPLOYMENT=distributor-gpt4o
AI_AGENT_HR_AZURE_DEPLOYMENT=hr-specialist
AI_AGENT_INVOICE_AZURE_DEPLOYMENT=invoice-specialist
AI_AGENT_INVENTORY_AZURE_DEPLOYMENT=inventory-specialist
AI_AGENT_INTEGRATOR_AZURE_DEPLOYMENT=integrator-gpt4o

# ─────────────────────────────────────────────────────────────
# Per-Agent Model Overrides (Gemini agents only)
# ─────────────────────────────────────────────────────────────
AI_AGENT_DISTRIBUTOR_MODEL=
AI_AGENT_HR_MODEL=
AI_AGENT_INVOICE_MODEL=
AI_AGENT_INVENTORY_MODEL=
AI_AGENT_INTEGRATOR_MODEL=

# ─────────────────────────────────────────────────────────────
# Per-Agent Temperature Overrides
# ─────────────────────────────────────────────────────────────
AI_AGENT_DISTRIBUTOR_TEMPERATURE=0.1
AI_AGENT_HR_TEMPERATURE=0.2
AI_AGENT_INVOICE_TEMPERATURE=0.2
AI_AGENT_INVENTORY_TEMPERATURE=0.2
AI_AGENT_INTEGRATOR_TEMPERATURE=0.1

# ─────────────────────────────────────────────────────────────
# Per-Agent Timeout & Retry Overrides
# ─────────────────────────────────────────────────────────────
AI_AGENT_DISTRIBUTOR_TIMEOUT=
AI_AGENT_DISTRIBUTOR_MAX_RETRIES=
AI_AGENT_HR_TIMEOUT=
AI_AGENT_HR_MAX_RETRIES=
AI_AGENT_INVOICE_TIMEOUT=
AI_AGENT_INVOICE_MAX_RETRIES=
AI_AGENT_INVENTORY_TIMEOUT=
AI_AGENT_INVENTORY_MAX_RETRIES=
AI_AGENT_INTEGRATOR_TIMEOUT=
AI_AGENT_INTEGRATOR_MAX_RETRIES=