{
  "project_name": "ERP Everything Possible Capability Test",
  "language": "en",
  "modules": {
    "access_control": {
      "enabled": true,
      "groups": [
        {
          "name": "Operations Manager",
          "responsibilities": "Runs inventory, receiving, sales orders, and cycle counts.",
          "permissions": ["view_records", "create_records", "edit_records", "approve_transactions"],
          "custom_permissions": "products.delete,stock_reservations.delete,cycle_count_sessions.delete"
        },
        {
          "name": "Billing Clerk",
          "responsibilities": "Creates invoices, records payments, and manages customer accounts.",
          "permissions": ["view_records", "create_records", "edit_records"],
          "custom_permissions": "invoices.delete,invoice_payments.delete,invoice_notes.delete"
        },
        {
          "name": "HR Manager",
          "responsibilities": "Manages staff, attendance, leave, timesheets, and payroll.",
          "permissions": ["view_records", "create_records", "edit_records", "approve_transactions"],
          "custom_permissions": "staff_members.delete,leave_requests.delete,payroll_ledger.delete"
        },
        {
          "name": "Read Only Auditor",
          "responsibilities": "Reviews business records, audit logs, and report snapshots.",
          "permissions": ["view_records"],
          "custom_permissions": "__audit_logs.read,__reports.read"
        }
      ]
    },
    "activity_log": {
      "enabled": true,
      "limit": 25
    },
    "inventory_dashboard": {
      "low_stock": {
        "enabled": true,
        "entity": "products",
        "quantity_field": "quantity",
        "reorder_point_field": "reorder_point",
        "limit": 10,
        "suggestion_multiplier": 1.5
      },
      "expiry": {
        "enabled": true,
        "entity": "products",
        "expiry_field": "expiry_date",
        "within_days": 30,
        "limit": 10
      }
    },
    "scheduled_reports": {
      "enabled": true,
      "cron": "0 1 * * *",
      "target_slug": "__reports",
      "report_type": "daily_summary",
      "entities": [
        "products",
        "stock_movements",
        "purchase_orders",
        "goods_receipts",
        "sales_orders",
        "customers",
        "invoices",
        "invoice_payments",
        "staff_members",
        "leave_requests",
        "attendance_logs",
        "timesheet_logs",
        "payroll_ledger"
      ],
      "low_stock": {
        "enabled": true,
        "entity": "products",
        "quantity_field": "quantity",
        "reorder_point_field": "reorder_point",
        "limit": 20
      },
      "expiry": {
        "enabled": true,
        "entity": "products",
        "expiry_field": "expiry_date",
        "within_days": 45,
        "limit": 20
      },
      "inventory_value": {
        "enabled": true,
        "entity": "products",
        "quantity_field": "quantity",
        "unit_price_field": "unit_cost",
        "limit": 100
      },
      "movements": {
        "enabled": true,
        "entity": "stock_movements",
        "type_field": "movement_type",
        "quantity_field": "quantity",
        "date_field": "movement_date",
        "item_ref_field": "item_id",
        "location_entity": "locations",
        "location_field": "location_id",
        "quantity_mode": "change",
        "lookback_days": 30,
        "limit": 100,
        "in_types": ["IN", "TRANSFER_IN"],
        "out_types": ["OUT", "TRANSFER_OUT"],
        "adjust_types": ["ADJUSTMENT"]
      },
      "entity_snapshots": [
        {
          "entity": "products",
          "display_field": "name",
          "fields": ["quantity", "reserved_quantity", "committed_quantity", "available_quantity", "reorder_point", "unit_cost"],
          "limit": 500,
          "sort_by": { "field": "name", "direction": "asc" }
        },
        {
          "entity": "invoices",
          "display_field": "invoice_number",
          "fields": ["status", "subtotal", "tax_total", "grand_total", "paid_total", "outstanding_balance"],
          "limit": 500
        },
        {
          "entity": "staff_members",
          "display_field": "first_name",
          "fields": ["status", "department_id", "job_title", "base_salary"],
          "limit": 500
        }
      ]
    },
    "inventory": {
      "enabled": true,
      "stock_entity": "products",
      "transactions": {
        "enabled": true,
        "quantity_field": "quantity"
      },
      "reservations": {
        "enabled": true,
        "reservation_entity": "stock_reservations",
        "item_field": "item_id",
        "quantity_field": "quantity",
        "status_field": "status",
        "reserved_field": "reserved_quantity",
        "committed_field": "committed_quantity",
        "available_field": "available_quantity"
      },
      "inbound": {
        "enabled": true,
        "purchase_order_entity": "purchase_orders",
        "purchase_order_item_entity": "purchase_order_items",
        "grn_entity": "goods_receipts",
        "grn_item_entity": "goods_receipt_items",
        "po_item_parent_field": "purchase_order_id",
        "po_item_item_field": "item_id",
        "po_item_ordered_field": "ordered_quantity",
        "po_item_received_field": "received_quantity",
        "grn_parent_field": "purchase_order_id",
        "grn_item_parent_field": "goods_receipt_id",
        "grn_item_po_item_field": "purchase_order_item_id",
        "grn_item_item_field": "item_id",
        "grn_item_received_field": "received_quantity",
        "grn_item_accepted_field": "accepted_quantity"
      },
      "cycle_counting": {
        "enabled": true,
        "session_entity": "cycle_count_sessions",
        "line_entity": "cycle_count_lines",
        "line_session_field": "cycle_count_session_id",
        "line_item_field": "item_id",
        "line_expected_field": "expected_quantity",
        "line_counted_field": "counted_quantity",
        "line_variance_field": "variance_quantity",
        "session_status_field": "status"
      }
    },
    "invoice": {
      "enabled": true,
      "tax_rate": 12,
      "currency": "USD",
      "payment_terms": 30,
      "prefix": "INV-",
      "transactions": {
        "enabled": true,
        "invoice_entity": "invoices",
        "invoice_item_entity": "invoice_items",
        "invoice_number_field": "invoice_number",
        "idempotency_field": "idempotency_key",
        "posted_at_field": "posted_at"
      },
      "payments": {
        "enabled": true,
        "payment_entity": "invoice_payments",
        "allocation_entity": "invoice_payment_allocations",
        "payment_number_field": "payment_number",
        "amount_field": "amount",
        "unallocated_field": "unallocated_amount",
        "status_field": "status",
        "allocation_payment_field": "payment_id",
        "allocation_invoice_field": "invoice_id",
        "allocation_amount_field": "allocated_amount"
      },
      "notes": {
        "enabled": true,
        "note_entity": "invoice_notes",
        "note_number_field": "note_number",
        "note_invoice_field": "source_invoice_id",
        "note_type_field": "note_type",
        "note_status_field": "status",
        "note_amount_field": "amount"
      },
      "lifecycle": {
        "enabled": true,
        "status_field": "status",
        "statuses": ["Draft", "Sent", "Paid", "Overdue", "Cancelled"],
        "enforce_transitions": true
      },
      "calculation_engine": {
        "enabled": true,
        "invoice_item_entity": "invoice_items",
        "item_invoice_field": "invoice_id",
        "item_quantity_field": "quantity",
        "item_unit_price_field": "unit_price",
        "item_line_subtotal_field": "line_subtotal",
        "item_discount_type_field": "line_discount_type",
        "item_discount_value_field": "line_discount_value",
        "item_discount_total_field": "line_discount_total",
        "item_tax_rate_field": "line_tax_rate",
        "item_tax_total_field": "line_tax_total",
        "item_additional_charge_field": "line_additional_charge",
        "item_line_total_field": "line_total"
      }
    },
    "hr": {
      "enabled": true,
      "employee_entity": "staff_members",
      "department_entity": "departments",
      "leave_entity": "leave_requests",
      "work_days": ["Mon", "Tue", "Wed", "Thu", "Fri"],
      "daily_hours": 8,
      "leave_engine": {
        "enabled": true,
        "leave_entity": "leave_requests",
        "balance_entity": "staff_leave_balances",
        "employee_field": "employee_id",
        "leave_type_field": "leave_type",
        "start_date_field": "start_date",
        "end_date_field": "end_date",
        "days_field": "requested_days",
        "entitlement_field": "annual_entitlement",
        "accrued_field": "accrued_days",
        "consumed_field": "consumed_days",
        "carry_forward_field": "carry_forward_days",
        "available_field": "remaining_days",
        "fiscal_year_field": "year",
        "default_entitlement": 18
      },
      "leave_approvals": {
        "enabled": true,
        "leave_entity": "leave_requests",
        "status_field": "approval_status",
        "approver_field": "approved_by",
        "approved_at_field": "approved_at",
        "rejected_at_field": "rejected_at",
        "rejection_reason_field": "rejection_reason",
        "decision_key_field": "decision_key",
        "statuses": ["Pending", "Approved", "Rejected", "Cancelled"],
        "enforce_transitions": true
      },
      "attendance_time": {
        "enabled": true,
        "attendance_entity": "attendance_logs",
        "shift_entity": "staff_shifts",
        "timesheet_entity": "timesheet_logs",
        "attendance_employee_field": "employee_id",
        "attendance_date_field": "work_date",
        "check_in_field": "check_in_at",
        "check_out_field": "check_out_at",
        "worked_hours_field": "worked_hours",
        "timesheet_hours_field": "regular_hours",
        "timesheet_overtime_field": "overtime_hours"
      },
      "compensation_ledger": {
        "enabled": true,
        "ledger_entity": "payroll_ledger",
        "snapshot_entity": "payroll_snapshots",
        "ledger_employee_field": "employee_id",
        "ledger_period_field": "pay_period",
        "ledger_type_field": "component_type",
        "ledger_amount_field": "amount"
      }
    }
  },
  "entities": [
    {
      "slug": "locations",
      "display_name": "Locations",
      "display_field": "name",
      "module": "inventory",
      "ui": { "search": true, "csv_import": true, "csv_export": true, "print": true },
      "list": { "columns": ["name", "code", "location_type", "is_active"] },
      "bulk_actions": { "enabled": true, "delete": true, "update_fields": ["location_type", "is_active"] },
      "fields": [
        { "name": "name", "type": "string", "label": "Location Name", "required": true, "unique": true, "min_length": 2 },
        { "name": "code", "type": "string", "label": "Location Code", "required": true, "unique": true, "pattern": "^[A-Z0-9-]+$" },
        { "name": "location_type", "type": "string", "label": "Type", "options": ["Warehouse", "Store", "Vehicle", "Virtual"], "required": true },
        { "name": "address", "type": "text", "label": "Address" },
        { "name": "is_active", "type": "boolean", "label": "Active", "default": true }
      ],
      "features": { "audit_trail": true }
    },
    {
      "slug": "suppliers",
      "display_name": "Suppliers",
      "display_field": "name",
      "module": "inventory",
      "ui": { "search": true, "csv_import": true, "csv_export": true, "print": true },
      "list": { "columns": ["name", "code", "email", "phone", "status"] },
      "bulk_actions": { "enabled": true, "delete": true, "update_fields": ["status"] },
      "fields": [
        { "name": "name", "type": "string", "label": "Supplier Name", "required": true },
        { "name": "code", "type": "string", "label": "Supplier Code", "unique": true },
        { "name": "email", "type": "string", "label": "Email" },
        { "name": "phone", "type": "string", "label": "Phone" },
        { "name": "address", "type": "text", "label": "Address" },
        { "name": "contact_person", "type": "string", "label": "Contact Person" },
        { "name": "status", "type": "string", "label": "Status", "options": ["Active", "Paused", "Blocked"], "required": true }
      ],
      "features": { "audit_trail": true }
    },
    {
      "slug": "customers",
      "display_name": "Customers",
      "display_field": "name",
      "module": "shared",
      "ui": { "search": true, "csv_import": true, "csv_export": true, "print": true },
      "list": { "columns": ["name", "email", "phone", "payment_terms", "credit_limit", "current_balance"] },
      "bulk_actions": { "enabled": true, "delete": true, "update_fields": ["payment_terms", "credit_limit"] },
      "fields": [
        { "name": "name", "type": "string", "label": "Customer Name", "required": true },
        { "name": "code", "type": "string", "label": "Customer Code", "unique": true },
        { "name": "email", "type": "string", "label": "Email" },
        { "name": "phone", "type": "string", "label": "Phone" },
        { "name": "billing_address", "type": "text", "label": "Billing Address" },
        { "name": "shipping_address", "type": "text", "label": "Shipping Address" },
        { "name": "tax_identifier", "type": "string", "label": "Tax/VAT ID" },
        { "name": "payment_terms", "type": "string", "label": "Payment Terms", "options": ["Due on receipt", "Net 7", "Net 15", "Net 30", "Net 60"] },
        { "name": "credit_limit", "type": "decimal", "label": "Credit Limit", "min": 0 },
        { "name": "current_balance", "type": "decimal", "label": "Current Balance", "computed": true }
      ],
      "features": { "audit_trail": true }
    },
    {
      "slug": "staff_members",
      "display_name": "Staff Members",
      "display_field": "first_name",
      "module": "shared",
      "ui": { "search": true, "csv_import": true, "csv_export": true, "print": true },
      "list": { "columns": ["first_name", "last_name", "department_id", "job_title", "status", "base_salary"] },
      "bulk_actions": { "enabled": true, "delete": true, "update_fields": ["department_id", "status", "job_title"] },
      "fields": [
        { "name": "first_name", "type": "string", "label": "First Name", "required": true },
        { "name": "last_name", "type": "string", "label": "Last Name", "required": true },
        { "name": "email", "type": "string", "label": "Email", "required": true, "unique": true },
        { "name": "phone", "type": "string", "label": "Phone" },
        { "name": "department_id", "type": "reference", "label": "Department", "reference_entity": "departments" },
        { "name": "job_title", "type": "string", "label": "Job Title" },
        { "name": "hire_date", "type": "date", "label": "Hire Date" },
        { "name": "status", "type": "string", "label": "Status", "required": true, "options": ["Active", "On Leave", "Terminated"] },
        { "name": "base_salary", "type": "decimal", "label": "Base Salary", "min": 0 },
        { "name": "linked_user_account", "type": "string", "label": "Linked ERP User" }
      ],
      "features": { "audit_trail": true }
    },
    {
      "slug": "products",
      "display_name": "Products",
      "display_field": "name",
      "module": "inventory",
      "ui": { "search": true, "csv_import": true, "csv_export": true, "print": true },
      "list": {
        "columns": ["sku", "name", "quantity", "reserved_quantity", "committed_quantity", "available_quantity", "reorder_point", "expiry_date"]
      },
      "bulk_actions": { "enabled": true, "delete": true, "update_fields": ["category", "reorder_point", "unit_cost", "location_id"] },
      "inventory_ops": {
        "enabled": true,
        "quantity_mode": "change",
        "movement_entity": "stock_movements",
        "location_entity": "locations",
        "quantity_field": "quantity",
        "entity_location_field": "location_id",
        "fields": {
          "item_ref": "item_id",
          "qty": "quantity",
          "type": "movement_type",
          "location": "location_id",
          "from_location": "from_location_id",
          "to_location": "to_location_id",
          "reason": "reason",
          "reference_number": "reference_number",
          "date": "movement_date"
        },
        "movement_types": {
          "receive": "IN",
          "issue": "OUT",
          "adjust": "ADJUSTMENT",
          "transfer_out": "TRANSFER_OUT",
          "transfer_in": "TRANSFER_IN"
        },
        "receive": { "enabled": true, "label": "Receive" },
        "issue": { "enabled": true, "label": "Issue", "allow_negative_stock": false },
        "adjust": { "enabled": true, "label": "Adjust", "reason_codes": ["COUNT", "DAMAGED", "EXPIRED", "RETURN", "OTHER"] },
        "transfer": { "enabled": true, "label": "Transfer" },
        "quick_actions": { "receive": true, "issue": true }
      },
      "labels": {
        "enabled": true,
        "type": "qrcode",
        "value_field": "sku",
        "text_fields": ["name", "sku", "location_id"],
        "columns": 3,
        "size": 160,
        "scan": true
      },
      "fields": [
        { "name": "sku", "type": "string", "label": "SKU", "required": true, "unique": true, "pattern": "^[A-Z0-9-]+$" },
        { "name": "name", "type": "string", "label": "Name", "required": true },
        { "name": "description", "type": "text", "label": "Description" },
        { "name": "category", "type": "string", "label": "Category", "options": ["Raw Material", "Finished Good", "Service", "Consumable"] },
        { "name": "quantity", "type": "decimal", "label": "On Hand", "required": true, "min": 0 },
        { "name": "reserved_quantity", "type": "decimal", "label": "Reserved", "min": 0, "default": 0, "computed": true },
        { "name": "committed_quantity", "type": "decimal", "label": "Committed", "min": 0, "default": 0, "computed": true },
        { "name": "available_quantity", "type": "decimal", "label": "Available", "min": 0, "computed": true },
        { "name": "reorder_point", "type": "decimal", "label": "Reorder Point", "min": 0 },
        { "name": "unit_cost", "type": "decimal", "label": "Unit Cost", "min": 0 },
        { "name": "sale_price", "type": "decimal", "label": "Sale Price", "min": 0 },
        { "name": "location_id", "type": "reference", "label": "Default Location", "reference_entity": "locations" },
        { "name": "batch_number", "type": "string", "label": "Batch Number" },
        { "name": "serial_number", "type": "string", "label": "Serial Number" },
        { "name": "expiry_date", "type": "date", "label": "Expiry Date" },
        { "name": "is_active", "type": "boolean", "label": "Active", "default": true }
      ],
      "features": {
        "inventory": true,
        "multi_location": true,
        "batch_tracking": true,
        "serial_tracking": true,
        "audit_trail": true
      }
    },
    {
      "slug": "stock_movements",
      "display_name": "Stock Movements",
      "display_field": "reference_number",
      "module": "inventory",
      "ui": { "search": true, "csv_import": true, "csv_export": true, "print": true },
      "list": { "columns": ["reference_number", "item_id", "movement_type", "quantity", "location_id", "movement_date"] },
      "bulk_actions": { "enabled": true, "delete": true, "update_fields": ["reason", "reference_number"] },
      "fields": [
        { "name": "item_id", "type": "reference", "label": "Item", "required": true, "reference_entity": "products" },
        { "name": "movement_type", "type": "string", "label": "Type", "required": true, "options": ["IN", "OUT", "ADJUSTMENT", "TRANSFER_IN", "TRANSFER_OUT"] },
        { "name": "quantity", "type": "decimal", "label": "Quantity", "required": true },
        { "name": "movement_date", "type": "datetime", "label": "Movement Date", "required": true },
        { "name": "reference_number", "type": "string", "label": "Reference" },
        { "name": "reason", "type": "text", "label": "Reason" },
        { "name": "location_id", "type": "reference", "label": "Location", "reference_entity": "locations" },
        { "name": "from_location_id", "type": "reference", "label": "From Location", "reference_entity": "locations" },
        { "name": "to_location_id", "type": "reference", "label": "To Location", "reference_entity": "locations" },
        { "name": "handled_by_id", "type": "reference", "label": "Handled By", "reference_entity": "staff_members" }
      ],
      "features": { "audit_trail": true }
    },
    {
      "slug": "stock_reservations",
      "display_name": "Stock Reservations",
      "display_field": "reservation_number",
      "module": "inventory",
      "ui": { "search": true, "csv_import": true, "csv_export": true, "print": true },
      "list": { "columns": ["reservation_number", "item_id", "quantity", "status", "source_reference"] },
      "fields": [
        { "name": "reservation_number", "type": "string", "label": "Reservation Number", "required": true, "unique": true },
        { "name": "item_id", "type": "reference", "label": "Item", "required": true, "reference_entity": "products" },
        { "name": "quantity", "type": "decimal", "label": "Quantity", "required": true, "min": 0 },
        { "name": "status", "type": "string", "label": "Status", "required": true, "options": ["Pending", "Released", "Committed", "Cancelled"] },
        { "name": "source_reference", "type": "string", "label": "Source Reference" },
        { "name": "note", "type": "text", "label": "Note" },
        { "name": "reserved_at", "type": "datetime", "label": "Reserved At" },
        { "name": "released_at", "type": "datetime", "label": "Released At" },
        { "name": "committed_at", "type": "datetime", "label": "Committed At" }
      ],
      "features": { "audit_trail": true }
    },
    {
      "slug": "purchase_orders",
      "display_name": "Purchase Orders",
      "display_field": "po_number",
      "module": "inventory",
      "ui": { "search": true, "csv_import": true, "csv_export": true, "print": true },
      "list": { "columns": ["po_number", "supplier_id", "order_date", "expected_date", "status", "total_amount"] },
      "children": [{ "entity": "purchase_order_items", "foreign_key": "purchase_order_id", "label": "Purchase Order Lines", "columns": ["item_id", "ordered_quantity", "received_quantity", "unit_price", "line_total"] }],
      "fields": [
        { "name": "po_number", "type": "string", "label": "PO Number", "required": true, "unique": true },
        { "name": "supplier_id", "type": "reference", "label": "Supplier", "required": true, "reference_entity": "suppliers" },
        { "name": "order_date", "type": "date", "label": "Order Date", "required": true },
        { "name": "expected_date", "type": "date", "label": "Expected Date" },
        { "name": "status", "type": "string", "label": "Status", "required": true, "options": ["Draft", "Sent", "Partially Received", "Received", "Cancelled"] },
        { "name": "total_amount", "type": "decimal", "label": "Total Amount", "computed": true },
        { "name": "notes", "type": "text", "label": "Notes" }
      ],
      "features": { "audit_trail": true }
    },
    {
      "slug": "purchase_order_items",
      "display_name": "Purchase Order Items",
      "display_field": "item_id",
      "module": "inventory",
      "ui": { "search": true, "csv_import": true, "csv_export": true, "print": true },
      "list": { "columns": ["purchase_order_id", "item_id", "ordered_quantity", "received_quantity", "unit_price", "line_total"] },
