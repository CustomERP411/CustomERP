      "reservations": {
        "enabled": true,
        "reservation_entity": "stock_reservations",
        "item_field": "item_id",
        "quantity_field": "quantity",
        "status_field": "status",
        "reserved_field": "reserved_quantity",
        "committed_field": "committed_quantity",
        "available_field": "available_quantity"
      },
      "inbound": {
        "enabled": true,
        "purchase_order_entity": "purchase_orders",
